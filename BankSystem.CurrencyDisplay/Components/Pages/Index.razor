@page "/"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.SignalR.Client
@implements IAsyncDisposable

<h2 style="text-align:center; color:#005a9e; font-size:2rem; margin:20px 0">
    💱 ВАЛЮТЫН ХАНШ
</h2>

<p style="text-align:center; font-size:0.9rem; color:gray">
    Шинэчлэгдсэн: @_lastUpdated.ToString("HH:mm:ss")
    @if (_connected)
    {
        <span style="color:green"> ● Холбогдсон</span>
    }
    else
    {
        <span style="color:red"> ● Холбогдоогүй</span>
    }
</p>

@if (_rates.Count == 0)
{
    <p style="text-align:center; color:gray; margin-top:40px">Ачааллаж байна...</p>
}
else
{
    <table style="width:100%; max-width:700px; margin:0 auto;
        border-collapse:collapse; font-size:1.3rem;">
        <thead>
            <tr style="background:#005a9e; color:white;">
                <th style="padding:14px; text-align:left">Валют</th>
                <th style="padding:14px; text-align:right">Авах (₮)</th>
                <th style="padding:14px; text-align:right">Зарах (₮)</th>
                <th style="padding:14px; text-align:right">Цаг</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var rate in _rates.Values)
            {
                <tr style="border-bottom:1px solid #ddd;
                    background:@(rate.IsNew ? "#fffde7" : "white")">
                    <td style="padding:14px; font-weight:bold; font-size:1.5rem">
                        @GetFlag(rate.CurrencyCode) @rate.CurrencyCode
                    </td>
                    <td style="padding:14px; text-align:right; color:#cc3300">
                        @rate.BuyRate.ToString("N0")
                    </td>
                    <td style="padding:14px; text-align:right; color:#006600">
                        @rate.SellRate.ToString("N0")
                    </td>
                    <td style="padding:14px; text-align:right;
                        font-size:0.9rem; color:gray">
                        @rate.UpdatedAt.ToString("HH:mm")
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    // Дэлгэц дээр харагдах ханшийн өгөгдөл.
    // IsNew=true үед мөрийн дэвсгэр шар болж, шинэ болсон ханшийг тодруулна.
    private record RateRow(string CurrencyCode, decimal BuyRate, decimal SellRate,
                           DateTime UpdatedAt, bool IsNew);

    private Dictionary<string, RateRow> _rates = new();
    private HubConnection? _hub;
    private bool _connected;
    private DateTime _lastUpdated = DateTime.Now;

    // Серверийн REST болон SignalR хаяг.
    // CurrencyDisplay өөр порт дээр (5273) ажиллана тул localhost:5272 бол BankServer.
    private const string ServerUrl = "http://localhost:5272";

    protected override async Task OnInitializedAsync()
    {
        await LoadRatesAsync();
        await ConnectHubAsync();
    }

    /// <summary>
    /// GET /api/exchangerate → анхны бүх ханшийг серверээс татна.
    /// Хуудас нээгдэх үед нэг удаа дуудагдана.
    /// </summary>
    private async Task LoadRatesAsync()
    {
        try
        {
            // Development орчинд self-signed cert-ийн шалгалтыг алгасна
            using var handler = new HttpClientHandler
            {
                ServerCertificateCustomValidationCallback = (_, _, _, _) => true
            };
            using var http = new HttpClient(handler);
            var rates = await http.GetFromJsonAsync<List<CurrencyRate>>(
                $"{ServerUrl}/api/exchangerate");

            if (rates is null) return;

            foreach (var r in rates)
                _rates[r.CurrencyCode] = new RateRow(
                    r.CurrencyCode, r.BuyRate, r.SellRate, r.UpdatedAt, IsNew: false);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"LoadRates алдаа: {ex.Message}");
        }
    }

    /// <summary>
    /// BankServer-ийн SignalR Hub-д холбогдоно.
    /// Теллер ханш өөрчлөхөд "ReceiveRateUpdate" event ирж
    /// хуудас refresh хийлгүйгээр автоматаар шинэчлэгдэнэ.
    /// WithAutomaticReconnect → холболт тасарвал дахин холбогдохыг оролдоно.
    /// </summary>
    private async Task ConnectHubAsync()
    {
        try
        {
            _hub = new HubConnectionBuilder()
                .WithUrl($"{ServerUrl}/bankhub")
                .WithAutomaticReconnect()
                .Build();

            // Теллер ханш өөрчлөхөд сервер энэ event-г broadcast хийнэ
            _hub.On<CurrencyRate>("ReceiveRateUpdate", rate =>
            {
                // IsNew=true тавьж шар дэвсгэрээр тодруулна
                _rates[rate.CurrencyCode] = new RateRow(
                    rate.CurrencyCode, rate.BuyRate, rate.SellRate,
                    rate.UpdatedAt, IsNew: true);
                _lastUpdated = DateTime.Now;
                // SignalR өөр thread дээр ажиллах тул InvokeAsync ашиглана
                InvokeAsync(StateHasChanged);
            });

            // Холболт тасарч дахин холбогдох үед статусыг шинэчилнэ
            _hub.Reconnected += _ =>
            {
                _connected = true;
                return InvokeAsync(StateHasChanged);
            };
            _hub.Reconnecting += _ =>
            {
                _connected = false;
                return InvokeAsync(StateHasChanged);
            };

            await _hub.StartAsync();
            _connected = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"ConnectHub алдаа: {ex.Message}");
        }
    }

    private static string GetFlag(string currency) => currency switch
    {
        "USD" => "🇺🇸",
        "EUR" => "🇪🇺",
        "CNY" => "🇨🇳",
        "RUB" => "🇷🇺",
        _     => "💰"
    };

    /// <summary>Компонент устах үед SignalR холболтыг хаана.</summary>
    public async ValueTask DisposeAsync()
    {
        if (_hub is not null)
            await _hub.DisposeAsync();
    }
}
